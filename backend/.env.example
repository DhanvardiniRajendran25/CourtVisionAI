# ── OpenAI (Scout Agent + Game Simulator) ─────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# Model to use for Scout Agent and Game Simulator
# Options: gpt-4o | gpt-4o-mini | gpt-4-turbo
OPENAI_SCOUT_MODEL=gpt-4o

# ── Google Gemini (Video Analysis only) ───────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# Video analyzer settings
VIDEO_ANALYZER_USE_GEMINI=false
VIDEO_ANALYZER_MODEL=gemini-1.5-pro
